{
  "name": "punktlandung",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "standards": "standards",
    "check": "bun test scripts/repository-artifacts.test.ts && standards check && turbo run lint check-types test build test:a11y",
    "check:fix": "bun test scripts/repository-artifacts.test.ts && standards check && turbo run lint:fix check-types test build test:a11y",
    "test:a11y": "turbo run test:a11y",
    "dev": "turbo run dev --filter=@punktlandung/web",
    "build": "turbo run build --filter=@punktlandung/web",
    "start": "turbo run start --filter=@punktlandung/web"
  },
  "engines": {
    "node": "26",
    "bun": "1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@davidvornholt/standards": "0.12.0",
    "turbo": "^2.10.6",
    "typescript": "7.0.2"
  }
}
