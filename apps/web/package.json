{
  "name": "@punktlandung/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "start": "bun run scripts/serve.ts",
    "check-types": "tsc --noEmit",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write --error-on-warnings .",
    "test": "bun test",
    "test:a11y": "playwright test --config playwright.config.ts",
    "db:up": "podman start punktlandung-db || podman run -d --name punktlandung-db -e POSTGRES_USER=punktlandung -e POSTGRES_PASSWORD=punktlandung -e POSTGRES_DB=punktlandung_dev -p 127.0.0.1:15432:5432 -v punktlandung-db-data:/var/lib/postgresql/data docker.io/library/postgres:17-alpine",
    "db:down": "podman stop punktlandung-db",
    "db:generate": "bun --env-file=.env.local run drizzle-kit generate",
    "db:migrate": "bun --env-file=.env.local run scripts/migrate.ts",
    "db:migrate:deploy": "bun run scripts/migrate.ts",
    "db:push": "bun --env-file=.env.local run drizzle-kit push",
    "db:studio": "bun --env-file=.env.local run drizzle-kit studio"
  },
  "dependencies": {
    "@effect/sql": "^0.52.0",
    "@effect/sql-drizzle": "^0.51.0",
    "@effect/sql-pg": "^0.53.0",
    "@fontsource-variable/hanken-grotesk": "^5.3.0",
    "@fontsource/spectral": "^5.3.0",
    "@punktlandung/ui": "workspace:*",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "better-auth": "^1.5.3",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.22.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.10.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@davidvornholt/a11y-testing": "workspace:*",
    "@davidvornholt/typescript-config": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  }
}
