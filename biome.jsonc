{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  // Repo-owned wrapper. Extends the canonical strict base synced from
  // davidvornholt/standards. Add project-specific overrides here; never edit
  // biome.base.jsonc locally.
  "extends": ["./biome.base.jsonc"],
  "files": {
    // Claude workflow scripts are a sandboxed DSL dialect (ambient
    // orchestration globals, top-level return) that Biome's ES module
    // parser rejects; the Workflow harness validates them at run time.
    // Claude agent worktrees are full checkouts with their own root
    // biome.jsonc; nested biome.json(c) files are scanner-priority special
    // files, so only force-ignore (`!!`) guarantees they are never discovered
    // as nested roots.
    // routeTree.gen.ts is generated by TanStack Router on every dev/build
    // run and explicitly asks to be excluded from linting and formatting;
    // it cannot conform to the repository style.
    // apps/web/drizzle is drizzle-kit's generated migration output (SQL +
    // meta snapshots); drizzle-kit rewrites it on every `db:generate`, so
    // formatting it would just fight the generator.
    "includes": [
      "**",
      "!.claude/workflows",
      "!!.claude/worktrees",
      "!apps/web/src/routeTree.gen.ts",
      "!apps/web/drizzle"
    ]
  },
  "overrides": [
    {
      // These framework boundaries require default exports as part of their
      // file-based configuration contracts (Vite, Playwright, Drizzle Kit).
      "includes": [
        "apps/web/vite.config.ts",
        "apps/web/playwright.config.ts",
        "apps/web/drizzle.config.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      // Designated environment boundaries: env.ts reads process.env exactly
      // once and validates it; drizzle.config.ts runs in drizzle-kit's CLI
      // context (also inside the migration container, where only
      // DATABASE_URL exists) and must not pull the full app env. Its
      // DATABASE_URL read is migrate-runtime-only, never a cached Turbo
      // task input, so it does not belong in turbo.json env declarations.
      // The UPPER_SNAKE keys are the dotenv wire format, not naming choices.
      "includes": ["apps/web/src/shared/env.ts", "apps/web/drizzle.config.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noProcessGlobal": "off"
          },
          "style": {
            "noProcessEnv": "off",
            "useNamingConvention": "off"
          },
          "suspicious": {
            "noUndeclaredEnvVars": "off"
          }
        }
      }
    },
    {
      // TanStack Start server routes: handler keys are the HTTP verbs
      // (GET/POST) and the splat route file must be named `$.ts` — both are
      // framework contracts, not naming choices.
      "includes": ["apps/web/src/routes/api/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off",
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      // The TanStack Start document shell renders the literal <head> element;
      // noHeadElement is a Next.js-domain rule and this is not a Next app.
      // Biome's resolver also cannot follow Vite's `?url` asset-query import
      // for the stylesheet; Vite and tsc remain the authoritative resolvers.
      "includes": ["apps/web/src/routes/__root.tsx"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnresolvedImports": "off"
          },
          "style": {
            "noHeadElement": "off"
          }
        }
      }
    },
    {
      // Data.TaggedError tag literals ("HalbjahrNichtGefunden", …) are stable
      // domain identifiers that the entropy-based secret heuristic
      // misclassifies as credentials.
      "includes": ["apps/web/src/features/*/errors/*.ts"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          }
        }
      }
    },
    {
      // Grade-math tests compare against literal numeric fixtures (Noten,
      // Punkte, Gewichte, Daten); naming each expected value would obscure
      // the arithmetic the tests pin down.
      "includes": ["apps/web/src/**/*.test.ts"],
      "linter": {
        "rules": {
          "style": {
            "noMagicNumbers": "off"
          }
        }
      }
    },
    {
      // App-owned operational scripts are Bun boundaries like the canonical
      // root scripts covered by biome.base.jsonc: the `Bun` global comes from
      // the Bun runtime (typed via @types/bun), and PORT is a runtime-only
      // server setting, not a Turborepo build input.
      "includes": ["apps/*/scripts/**"],
      "javascript": {
        "globals": ["Bun"]
      },
      "linter": {
        "rules": {
          "correctness": {
            "noNodejsModules": "off"
          },
          "suspicious": {
            "noUndeclaredEnvVars": "off"
          }
        }
      }
    }
  ]
}
